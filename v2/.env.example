# API Configuration
ANTHROPIC_API_KEY=
# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (optional)
# Leave empty to allow all origins, or specify specific domains
CORS_ORIGIN=http://localhost:5000,http://localhost:3000
# Supabase Postgres Database Configuration
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
JWT_SECRET=your_jwt_fallback_secret

